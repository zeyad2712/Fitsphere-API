                                        "example": "Ziad Waleed"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "ziad.waleed@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "newpassword123"
                                    },
                                    "phone": {
                                        "type": "string",
                                        "example": "+201234567890"
                                    },
                                    "birth_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "1999-05-15"
                                    },
                                    "height": {
                                        "type": "number",
                                        "example": 182
                                    },
                                    "weight": {
                                        "type": "number",
                                        "example": 78
                                    },
                                    "fitness_goal": {
                                        "type": "string",
                                        "example": "Hypertrophy"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Profile updated successfully"
                    }
                }
            }
        }
