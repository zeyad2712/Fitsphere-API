        "/trainers": {
            "get": {
                "tags": [
                    "Trainers"
                ],
                "summary": "List all trainers with advanced filtering and sorting",
                "operationId": "ee552e84cfffce7d4ca2567030d8a29a",
                "parameters": [
                    {
                        "name": "name",
                        "in": "query",
                        "description": "Filter by trainer name",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "speciality",
                        "in": "query",
                        "description": "Filter by specialization",
                        "required": false,
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "min_price",
                        "in": "query",
                        "description": "Minimum price per month",
                        "required": false,
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "max_price",
                        "in": "query",
                        "description": "Maximum price per month",
                        "required": false,
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "min_rating",
                        "in": "query",
                        "description": "Minimum average rating (e.g. 4.0)",
                        "required": false,
                        "schema": {
                            "type": "number"
                        }
                    },
                    {
                        "name": "sort_by",
                        "in": "query",
                        "description": "Sort by option (top_rated, price_asc, price_desc)",
                        "required": false,
                        "schema": {
                            "type": "string",
                            "enum": [
                                "top_rated",
                                "price_asc",
                                "price_desc"
                            ]
                        }
                    }
                ],
                "responses": {
